{
  "id": "methodology-designer",
  "name": "研究方法设计器",
  "version": "v1.0.0",
  "description": "根据研究问题设计完整的研究方法论蓝图，包括研究范式、方法选择、数据策略、分析框架和效度标准。",
  "min_app_version": "v1.4.0",
  "entry": {
    "module": "entry",
    "class": "MethodologyDesignerSkill"
  },
  "priority": 10,
  "actions": [
    {
      "id": "design_methodology",
      "label": "设计研究方法",
      "description": "根据研究问题设计完整的研究方法论方案。",
      "input_schema": {
        "fields": [
          {
            "id": "research_question",
            "label": "研究问题",
            "type": "textarea",
            "required": true,
            "placeholder": "描述你的核心研究问题"
          },
          {
            "id": "discipline",
            "label": "学科领域",
            "type": "select",
            "required": true,
            "default": "social_science",
            "options": [
              {"label": "社会科学", "value": "social_science"},
              {"label": "自然科学", "value": "natural_science"},
              {"label": "人文学科", "value": "humanities"},
              {"label": "工程技术", "value": "engineering"},
              {"label": "医学健康", "value": "medical"},
              {"label": "管理学", "value": "management"},
              {"label": "教育学", "value": "education"},
              {"label": "其他", "value": "other"}
            ]
          },
          {
            "id": "research_type",
            "label": "研究类型偏好",
            "type": "select",
            "required": false,
            "default": "auto",
            "options": [
              {"label": "自动推荐", "value": "auto"},
              {"label": "定量研究", "value": "quantitative"},
              {"label": "定性研究", "value": "qualitative"},
              {"label": "混合研究", "value": "mixed"},
              {"label": "不确定", "value": "unsure"}
            ]
          },
          {
            "id": "constraints",
            "label": "研究限制",
            "type": "textarea",
            "required": false,
            "placeholder": "描述你的研究限制（时间、资源、数据可得性等）"
          }
        ]
      }
    },
    {
      "id": "evaluate_methodology",
      "label": "评估研究方法",
      "description": "评估现有研究方法设计的合理性和可行性。",
      "input_schema": {
        "fields": [
          {
            "id": "methodology",
            "label": "研究方法描述",
            "type": "textarea",
            "required": true,
            "placeholder": "描述你的研究方法设计"
          },
          {
            "id": "research_question",
            "label": "研究问题",
            "type": "textarea",
            "required": true,
            "placeholder": "你的研究问题是什么？"
          }
        ]
      }
    },
    {
      "id": "suggest_analysis",
      "label": "推荐分析方法",
      "description": "根据数据类型和研究问题推荐合适的分析方法。",
      "input_schema": {
        "fields": [
          {
            "id": "data_type",
            "label": "数据类型",
            "type": "select",
            "required": true,
            "default": "quantitative",
            "options": [
              {"label": "定量数据", "value": "quantitative"},
              {"label": "定性数据", "value": "qualitative"},
              {"label": "混合数据", "value": "mixed"},
              {"label": "文本数据", "value": "text"},
              {"label": "时间序列", "value": "time_series"},
              {"label": "空间数据", "value": "spatial"}
            ]
          },
          {
            "id": "research_question",
            "label": "研究问题",
            "type": "textarea",
            "required": true,
            "placeholder": "你的研究问题是什么？"
          },
          {
            "id": "sample_size",
            "label": "样本量",
            "type": "text",
            "required": false,
            "placeholder": "预计样本量（如：100人、500份问卷）"
          }
        ]
      }
    }
  ],
  "scene_bindings": [
    "paper_write.outline",
    "paper_write.section"
  ],
  "global_hook": false
}
